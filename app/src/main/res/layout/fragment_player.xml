<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/playerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorPrimary"
    android:theme="@style/Theme.PlaylistMaker.Search">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/playerScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/playerContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" >

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/leftBorderTrack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_begin="24dp" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/rightBorderTrack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_end="24dp" />

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarPlayer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="?attr/colorSurface"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/cover"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="30dp"
            android:contentDescription="@null"
            app:layout_constraintTop_toBottomOf="@id/toolbarPlayer"
            app:layout_constraintStart_toStartOf="@id/leftBorderTrack"
            app:layout_constraintEnd_toEndOf="@id/rightBorderTrack"
            app:layout_constraintDimensionRatio="1:1" />

        <TextView
            android:id="@+id/titleTrack"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            style="@style/titleTrack"
            app:layout_constraintTop_toBottomOf="@id/cover"
            app:layout_constraintStart_toStartOf="@id/cover"
            app:layout_constraintEnd_toEndOf="@id/cover" />

        <TextView
            android:id="@+id/artist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            style="@style/artist"
            app:layout_constraintTop_toBottomOf="@id/titleTrack"
            app:layout_constraintStart_toStartOf="@id/titleTrack"
            app:layout_constraintEnd_toEndOf="@id/titleTrack" />

        <ImageButton
            android:id="@+id/addPlaylist"
            android:layout_width="51dp"
            android:layout_height="51dp"
            android:layout_marginTop="54dp"
            android:contentDescription="@null"
            android:enabled="false"
            android:src="@drawable/ic_add_playlist54"
            app:layout_constraintTop_toBottomOf="@id/artist"
            app:layout_constraintStart_toStartOf="@id/artist"
            style="?attr/materialIconButtonStyle"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <ImageButton
            android:id="@+id/play"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="30dp"
            android:contentDescription="@null"
            android:enabled="false"
            android:src="@drawable/ic_button_play100"
            app:tint="?attr/colorOnSurface"
            app:layout_constraintTop_toBottomOf="@id/artist"
            app:layout_constraintStart_toEndOf="@id/addPlaylist"
            app:layout_constraintEnd_toStartOf="@id/like"
            app:layout_constraintBottom_toTopOf="@id/durationTrack"
            style="?attr/materialIconButtonStyle"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <ImageButton
            android:id="@+id/like"
            android:layout_width="51dp"
            android:layout_height="51dp"
            android:layout_marginTop="54dp"
            android:contentDescription="@null"
            android:enabled="false"
            android:src="@drawable/ic_like51_inactive"
            app:layout_constraintTop_toBottomOf="@id/artist"
            app:layout_constraintEnd_toEndOf="@id/artist"
            style="?attr/materialIconButtonStyle"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:id="@+id/durationTrack"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            style="@style/durationTrack"
            app:layout_constraintTop_toBottomOf="@id/play"
            app:layout_constraintStart_toStartOf="@id/play"
            app:layout_constraintEnd_toEndOf="@id/play" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/leftBorderDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_begin="16dp" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/rightBorderDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_end="16dp" />

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/labelsBarrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="end"
            app:constraint_referenced_ids="descriptionDurationText,descriptionAlbumText, descriptionYearText, descriptionGenreText" />

        <TextView
            android:id="@+id/descriptionDurationText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/duration"
            android:layout_marginTop="30dp"
            style="@style/descriptionTrackText"
            app:layout_constraintStart_toStartOf="@id/leftBorderDescription"
            app:layout_constraintTop_toBottomOf="@id/durationTrack" />

        <TextView
            android:id="@+id/descriptionDurationValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            style="@style/descriptionTrackValue"
            app:layout_constraintTop_toBottomOf="@id/durationTrack"
            app:layout_constraintStart_toEndOf="@id/labelsBarrier"
            app:layout_constraintEnd_toStartOf="@id/rightBorderDescription"
            app:layout_constraintBaseline_toBaselineOf="@id/descriptionDurationText"/>

        <TextView
            android:id="@+id/descriptionAlbumText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/album"
            android:layout_marginTop="17dp"
            style="@style/descriptionTrackText"
            app:layout_constraintStart_toStartOf="@id/leftBorderDescription"
            app:layout_constraintTop_toBottomOf="@id/descriptionDurationText" />

        <TextView
            android:id="@+id/descriptionAlbumValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            style="@style/descriptionTrackValue"
            android:layout_marginTop="17dp"
            app:layout_constraintTop_toBottomOf="@id/descriptionDurationValue"
            app:layout_constraintStart_toEndOf="@id/labelsBarrier"
            app:layout_constraintEnd_toStartOf="@id/rightBorderDescription"
            app:layout_constraintBaseline_toBaselineOf="@id/descriptionAlbumText" />

        <TextView
            android:id="@+id/descriptionYearText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/year"
            style="@style/descriptionTrackText"
            android:layout_marginTop="17dp"
            app:layout_constraintStart_toStartOf="@id/leftBorderDescription"
            app:layout_constraintTop_toBottomOf="@id/descriptionAlbumText" />

        <TextView
            android:id="@+id/descriptionYearValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            style="@style/descriptionTrackValue"
            android:layout_marginTop="17dp"
            app:layout_constraintTop_toBottomOf="@id/descriptionAlbumValue"
            app:layout_constraintStart_toEndOf="@id/labelsBarrier"
            app:layout_constraintEnd_toStartOf="@id/rightBorderDescription"
            app:layout_constraintBaseline_toBaselineOf="@id/descriptionYearText" />

        <TextView
            android:id="@+id/descriptionGenreText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/genre"
            style="@style/descriptionTrackText"
            android:layout_marginTop="17dp"
            app:layout_constraintStart_toStartOf="@id/leftBorderDescription"
            app:layout_constraintTop_toBottomOf="@id/descriptionYearText" />

        <TextView
            android:id="@+id/descriptionGenreValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            style="@style/descriptionTrackValue"
            android:layout_marginTop="17dp"
            app:layout_constraintTop_toBottomOf="@id/descriptionYearValue"
            app:layout_constraintStart_toEndOf="@id/labelsBarrier"
            app:layout_constraintEnd_toStartOf="@id/rightBorderDescription"
            app:layout_constraintBaseline_toBaselineOf="@id/descriptionGenreText" />

        <TextView
            android:id="@+id/descriptionCountryText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/country"
            style="@style/descriptionTrackText"
            android:layout_marginTop="17dp"
            android:layout_marginBottom="20dp"
            app:layout_constraintStart_toStartOf="@id/leftBorderDescription"
            app:layout_constraintTop_toBottomOf="@id/descriptionGenreText" />

        <TextView
            android:id="@+id/descriptionCountryValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            style="@style/descriptionTrackValue"
            android:layout_marginTop="17dp"
            android:paddingBottom="20dp"
            app:layout_constraintTop_toBottomOf="@id/descriptionGenreValue"
            app:layout_constraintStart_toEndOf="@id/labelsBarrier"
            app:layout_constraintEnd_toStartOf="@id/rightBorderDescription"
            app:layout_constraintBaseline_toBaselineOf="@id/descriptionCountryText" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <View
        android:id="@+id/bottomSheetOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bottom_sheet_overlay"
        android:clickable="true"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/addToPlaylistBottomSheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bottom_sheet_background"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        app:behavior_hideable="true"
        app:behavior_peekHeight="0dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <View
            android:id="@+id/bottomSheetHandle"
            android:layout_width="50dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bottom_sheet_handle" />

        <TextView
            android:id="@+id/bottomSheetTitle"
            style="@style/BottomSheetTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="@string/add_to_playlist_title" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/bottomSheetNewPlaylistButton"
            style="@style/NewPlaylist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="28dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/playlistsBottomSheetRecycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:overScrollMode="never"
            android:layout_weight="1"
            android:clipToPadding="false"
            tools:listitem="@layout/item_playlist_bottom_sheet" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>